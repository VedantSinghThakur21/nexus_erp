{
  "doctype": "DocType",
  "name": "Agent Action Log",
  "module": "Custom",
  "custom": 1,
  "is_submittable": 0,
  "track_changes": 1,
  "autoname": "hash",
  "fields": [
    {
      "fieldname": "tenant",
      "fieldtype": "Data",
      "label": "Tenant",
      "in_list_view": 1
    },
    {
      "fieldname": "tool_name",
      "fieldtype": "Data",
      "label": "Tool Name",
      "in_list_view": 1
    },
    {
      "fieldname": "action",
      "fieldtype": "Data",
      "label": "Action"
    },
    {
      "fieldname": "action_type",
      "fieldtype": "Select",
      "label": "Action Type",
      "options": "follow_up_scan\nstale_lead_scan\noverdue_invoice_scan\nmanual",
      "default": "manual",
      "in_list_view": 1
    },
    {
      "fieldname": "status",
      "fieldtype": "Select",
      "label": "Status",
      "options": "pending_approval\napproved\nrejected\nexecuted\nfailed",
      "default": "pending_approval",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "triggered_by",
      "fieldtype": "Data",
      "label": "Triggered By"
    },
    {
      "fieldname": "created_by",
      "fieldtype": "Data",
      "label": "Created By"
    },
    {
      "fieldname": "approved_by",
      "fieldtype": "Data",
      "label": "Approved By",
      "in_list_view": 1
    },
    {
      "fieldname": "approved_at",
      "fieldtype": "Datetime",
      "label": "Approved At"
    },
    {
      "fieldname": "rejected_reason",
      "fieldtype": "Small Text",
      "label": "Reject Reason"
    },
    {
      "fieldname": "rejected_at",
      "fieldtype": "Datetime",
      "label": "Rejected At"
    },
    {
      "fieldname": "executed_at",
      "fieldtype": "Datetime",
      "label": "Executed At"
    },
    {
      "fieldname": "payload",
      "fieldtype": "Long Text",
      "label": "Payload"
    },
    {
      "fieldname": "dry_run",
      "fieldtype": "Long Text",
      "label": "Dry Run Preview"
    },
    {
      "fieldname": "result",
      "fieldtype": "Long Text",
      "label": "Result"
    },
    {
      "fieldname": "idempotency_key",
      "fieldtype": "Data",
      "label": "Idempotency Key",
      "unique": 1
    },
    {
      "fieldname": "rolled_back",
      "fieldtype": "Check",
      "label": "Rolled Back",
      "default": "0"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1,
      "report": 1,
      "export": 1
    },
    {
      "role": "Sales Manager",
      "read": 1,
      "write": 1,
      "create": 1
    },
    {
      "role": "Projects Manager",
      "read": 1,
      "write": 0,
      "create": 0
    }
  ]
}
